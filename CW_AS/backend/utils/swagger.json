{
  "openapi": "3.0.0",
  "info": {
    "title": "Alumni Influencers API - w1956194",
    "version": "1.0.0",
    "description": "API documentation for the Alumni Influencers backend system. Student ID: w1956194"
  },
  "servers": [
    {
      "url": "http://localhost:3000",
      "description": "Development Server"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      },
      "apiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "x-api-key"
      }
    }
  },
  "paths": {
    "/api/auth/register": {
      "post": {
        "tags": ["Authentication"],
        "summary": "Register a new user",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": { "type": "string", "format": "email" },
                  "password": { "type": "string" }
                },
                "required": ["email", "password"]
              }
            }
          }
        },
        "responses": {
          "201": { "description": "User registered successfully" },
          "400": { "description": "Invalid input" }
        }
      }
    },
    "/api/auth/login": {
      "post": {
        "tags": ["Authentication"],
        "summary": "Login to the system",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": { "type": "string", "format": "email" },
                  "password": { "type": "string" }
                },
                "required": ["email", "password"]
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Login successful" },
          "401": { "description": "Invalid credentials" }
        }
      }
    },
    "/api/auth/verify/{token}": {
      "get": {
        "tags": ["Authentication"],
        "summary": "Verify email address",
        "parameters": [
          {
            "name": "token",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": { "description": "Verification successful" },
          "400": { "description": "Invalid token" }
        }
      }
    },
    "/api/auth/logout": {
      "post": {
        "tags": ["Authentication"],
        "summary": "Logout and terminate session",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "Logout successful" }
        }
      }
    },
    "/api/auth/forgot-password": {
      "post": {
        "tags": ["Authentication"],
        "summary": "Request password reset link",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": { "type": "string", "format": "email" }
                },
                "required": ["email"]
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Reset link sent if email exists" }
        }
      }
    },
    "/api/auth/reset-password": {
      "post": {
        "tags": ["Authentication"],
        "summary": "Reset password using token",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "token": { "type": "string" },
                  "newPassword": { "type": "string" }
                },
                "required": ["token", "newPassword"]
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Password updated successfully" }
        }
      }
    },
    "/api/profile/profile": {
      "get": {
        "tags": ["Profile"],
        "summary": "Get current user profile",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "Profile data retrieved" }
        }
      },
      "post": {
        "tags": ["Profile"],
        "summary": "Update current user profile",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "apd_full_name": { "type": "string" },
                  "apd_bio": { "type": "string" },
                  "apd_linkedIn_url": { "type": "string" },
                  "apd_profile_image": { "type": "string", "format": "binary" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Profile updated successfully" }
        }
      }
    },
    "/api/alumni": {
      "get": {
        "tags": ["Alumni"],
        "summary": "Get filtered list of alumni",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "programme", "in": "query", "schema": { "type": "string" } },
          { "name": "graduationYear", "in": "query", "schema": { "type": "integer" } },
          { "name": "sector", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "List of alumni" }
        }
      }
    },
    "/api/analytics": {
      "get": {
        "tags": ["Analytics"],
        "summary": "Main dashboard analytics data",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "x-api-key", "in": "header", "required": true, "schema": { "type": "string" } },
          { "name": "programme", "in": "query", "schema": { "type": "string" } },
          { "name": "graduationYear", "in": "query", "schema": { "type": "integer" } },
          { "name": "sector", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Analytics data" }
        }
      }
    },
    "/api/analytics/filters": {
      "get": {
        "tags": ["Analytics"],
        "summary": "Get filter options for analytics",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "Filter options list" }
        }
      }
    }
  }
}